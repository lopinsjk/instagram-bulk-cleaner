{
  "manifest_version": 3,
  "name": "Instagram Bulk Cleaner",
  "version": "1.0.0",
  "description": "Rimuovi in bulk tutti i like e i commenti da Instagram",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["https://www.instagram.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://www.instagram.com/your_activity/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
